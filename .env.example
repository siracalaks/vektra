# ─── Vektra — environment template ──────────────────────────────────────────
# Copy this file to `.env` (gitignored) for the local Python scripts, OR paste
# the same values straight into the n8n Code node's CONFIG (recommended — that
# way keys live only in n8n and never touch git).
#
# NOTHING here is required just to OPEN the dashboard. These power the engine.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required for the auto-engine ──
ANTHROPIC_API_KEY=             # Claude Haiku = the "brain" (scoring + Sor answers) — https://console.anthropic.com
GEMINI_API_KEY=                # Google Gemini = embeddings (semantic search)      — https://aistudio.google.com/apikey
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=     # server-side only (n8n). NEVER expose to the browser.
SUPABASE_ANON_KEY=             # browser-safe key — you paste this into the dashboard's Settings tab, not here

# ── Optional sources / features (leave blank to skip) ──
GITHUB_TOKEN=                  # raises GitHub API limit + enables README deep-read
FIRECRAWL_API_KEY=             # deep-read non-GitHub web pages
YOUTUBE_API_KEY=               # YouTube Data API v3 — video tutorials as intel
APIFY_TOKEN=                   # Reddit + Instagram harvest (Apify actors; paid/opt-in)
PRODUCT_HUNT_TOKEN=            # Product Hunt top launches

# ── Optional WhatsApp morning brief (Evolution API) — all four, or none ──
EVOLUTION_URL=
EVOLUTION_INSTANCE=
EVOLUTION_API_KEY=
WHATSAPP_TO=                   # international format, e.g. 4915112345678

# ── MCP server (query Vektra from any Claude project) ──
VEKTRA_ASK_URL=https://YOUR-n8n-domain/webhook/vektra-ask
VEKTRA_ASK_KEY=                # the webhook token, if you set one
